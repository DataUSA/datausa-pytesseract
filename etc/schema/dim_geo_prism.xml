<Schema name="datausa" default_locale="en">
    <SharedDimension name="Geography PRISM">
      <Hierarchy name="State" default_member="Nation.01000US">
        <Table name="shapes2017_states"/>
        <Level key_column="nation_id" name="Nation" key_type="str" visible="false"/>
        <Level key_column="geoid" name_column="name" name="State" key_type="str">
          <Property name="Area" key_column="aland" />
        </Level>
      </Hierarchy>

      <Hierarchy name="County">
        <Table name="shapes2025_counties"/>
        <Level key_column="state_id" name_column="state_name" name="State County" key_type="str"/>
        <Level key_column="geoid" name_column="name" name="County" key_type="str">
          <Property name="Area" key_column="aland" />
        </Level>
      </Hierarchy>
    </SharedDimension>

    <SharedDimension name="Geography County PRISM">
      <Hierarchy name="County">
        <Table name="shapes2025_counties"/>
        <Level key_column="state_id" name_column="state_name" name="State" key_type="str"/>
        <Level key_column="geoid" name_column="name" name="County" key_type="str">
          <Property name="Area" key_column="aland" />
        </Level>
      </Hierarchy>
    </SharedDimension>

    <SharedDimension name="Geography Tract PRISM">
      <Hierarchy name="Tract">
        <Table name="shapes2025_tracts"/>
        <Level key_column="state_id" name_column="state_name" name="State" key_type="str"/>
        <Level key_column="county_id" name_column="county_name" name="County" key_type="str" />
        <Level key_column="geoid" name_column="name" name="Tract" key_type="str" />
      </Hierarchy>
    </SharedDimension>
</Schema>