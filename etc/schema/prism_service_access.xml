<Schema name="datausa" default_locale="en">
    <Cube name="prism_service_access" subset_table="true">
        <Annotation name="source_name">Deloitte's PeoplePrism</Annotation>
        <Annotation name="source_link">https://peopleprism.ai/</Annotation>
        <Annotation name="topic">PRISM</Annotation>
        <Annotation name="subtopic">Healthcare Access</Annotation>
        
        <Table name="prism_service_access" />

        <DimensionUsage foreign_key="geoid" name="Geography" source="Geography PRISM" />

        <Dimension foreign_key="type" name="Type of Health Provider">
            <Hierarchy name="Type of Health Provider">
                <InlineTable name="dim_0_table" format="tuples">
                    <Row>("member_0_code", "member_0")</Row>
                    <Row>(1, "Maternal Health Services")</Row>
                    <Row>(2, "Mental Health Services")</Row>
                    <Row>(3, "Emergency Care Services")</Row>
                    <Row>(4, "Child Healthcare Services")</Row>
                </InlineTable>
                <Level key_column="member_0_code" name="Health Provider" name_column="member_0" key_type="u8"/>
            </Hierarchy>
        </Dimension>

        <Dimension foreign_key="distance_id" name="Average Distance Range">
            <Hierarchy name="Total" default_member="Total.0">
                <InlineTable name="dim_1_table" format="tuples">
                    <Row>("member_total_code", "member_total")</Row>
                    <Row>(0, "Total")</Row>
                </InlineTable>
                <Level key_column="member_total_code" name="Total" name_column="member_total" key_type="u8"/>
            </Hierarchy>
            <Hierarchy name="Average Distance Range">
                <InlineTable name="dim_1_table" format="tuples">
                    <Row>("member_0_code", "member_0")</Row>
                    <Row>(1, "0-5 miles")</Row>
                    <Row>(2, "6-10 miles")</Row>
                    <Row>(3, "11-20 miles")</Row>
                    <Row>(4, "21-30 miles")</Row>
                    <Row>(5, "More than 30 miles")</Row>
                </InlineTable>
                <Level key_column="member_0_code" name="Average Distance Range" name_column="member_0" key_type="u8"/>
            </Hierarchy>
        </Dimension>
        
        <Measure aggregator="avg" key_column="avg_distance" name="Average estimated driving distance (miles)" visible="true" />
        <Measure aggregator="median" key_column="median_distance" name="Median estimated driving distance (miles)" visible="true" />
        <Measure aggregator="sum" key_column="household_count" name="Household Count" visible="true" />
    </Cube>
</Schema>
